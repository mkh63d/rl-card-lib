[flake8]
max-line-length = 100
extend-ignore = E203, E501, W503, W293, W291
exclude = 
    .git,
    __pycache__,
    build,
    dist,
    *.egg-info,
    .venv,
    venv,
    .tox
per-file-ignores =
    __init__.py: F401
    # E402: test_trainer.py must set the matplotlib backend before importing
    # anything that pulls in pyplot.
    tests/*: E501, F401, E402
    packages/*/tests/*: E501, F401
